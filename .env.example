# Supabase Configuration
VITE_SUPABASE_PROJECT_ID="your-project-id"
VITE_SUPABASE_PUBLISHABLE_KEY="your-anon-key"
VITE_SUPABASE_URL="https://your-project.supabase.co"

# Sentry Monitoring
VITE_SENTRY_DSN="https://your-key@sentry.io/your-project"
VITE_SENTRY_TRACES_SAMPLE_RATE="0.2"
VITE_ENABLE_SESSION_REPLAY="true"
VITE_REPLAY_SAMPLE_RATE="0.05"
VITE_REPLAY_ERROR_SAMPLE_RATE="1.0"
VITE_RELEASE_VERSION="1.0.0"
VITE_MEMORY_MONITOR_SAMPLE_RATE="0.05"
VITE_RAGE_CLICK_SAMPLE_RATE="0.2"

# Third-Party APIs
VITE_MAPBOX_PUBLIC_TOKEN="pk.your-mapbox-token"
VITE_GOOGLE_PLACES_API_KEY="your-google-places-key"
VITE_INSTAGRAM_APP_ID="your-instagram-app-id"
